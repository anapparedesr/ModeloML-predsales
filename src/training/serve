#!/usr/bin/env python3
"""
serve
-----
Entry point para el servidor de inferencia en SageMaker.
Arranca gunicorn que carga la app Flask de predictor.py.
"""

import multiprocessing
import os
import subprocess
import sys

model_server_timeout = os.environ.get("MODEL_SERVER_TIMEOUT", 60)
model_server_workers = int(
    os.environ.get("MODEL_SERVER_WORKERS", multiprocessing.cpu_count())
)


def start_server():
    print(f"Starting inference server with {model_server_workers} workers...")

    gunicorn = subprocess.Popen([
        "gunicorn",
        "--timeout", str(model_server_timeout),
        "-k", "sync",
        "-b", "0.0.0.0:8080",
        "-w", str(model_server_workers),
        "predictor:app",
    ])

    gunicorn.wait()
    print("Inference server exiting")


if __name__ == "__main__":
    start_server()