# ─────────────────────────────────────────
# Data
# ─────────────────────────────────────────
# Ignoramos el CONTENIDO de las carpetas, pero no las carpetas en sí
data/raw/*
!data/raw/.gitkeep

data/prep/*
!data/prep/.gitkeep

data/inference/*
!data/inference/.gitkeep

data/predictions/*
!data/predictions/.gitkeep

# Seguimos ignorando todos los CSV en cualquier lugar por seguridad
*.csv
# ─────────────────────────────────────────
# Artifacts (modelos entrenados y logs)
# ─────────────────────────────────────────
artifacts/*.pkl
artifacts/logs/

# ─────────────────────────────────────────
# Python
# ─────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

